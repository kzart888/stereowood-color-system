# STEREOWOOD Color System Environment Configuration
# Copy this file to .env and update with your values

# Server Configuration
PORT=9099
NODE_ENV=production
ENABLE_PILOT_UI=false
PILOT_DICTIONARY_WRITE=false

# Database
DB_FILE=/data/color_management.db
# Optional backup location used by npm run backup/restore
# BACKUP_DIR=/app/backend/backups

# Timezone
TZ=Asia/Shanghai

# Auth / Access Control (A4)
AUTH_ENFORCE_WRITES=false
READ_ONLY_MODE=false
SESSION_TTL_HOURS=720
COOKIE_SECURE=false
# Legacy x-admin-key compatibility (recommended false)
ALLOW_LEGACY_ADMIN_KEY=false
# Required only when ALLOW_LEGACY_ADMIN_KEY=true
INTERNAL_ADMIN_KEY=change-this-before-production

# Docker Hub Configuration (for GitHub Actions)
# Add these as GitHub Secrets, not in .env file!
# DOCKER_HUB_USERNAME=your-dockerhub-username
# DOCKER_HUB_TOKEN=your-dockerhub-token

# Synology Deployment
HOST_PORT=9099
PILOT_HOST_PORT=9199
DOCKER_IMAGE=yourusername/stereowood-color-system:latest
