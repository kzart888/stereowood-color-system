# STEREOWOOD Color System Environment Configuration
# Copy this file to .env and update with your values

# Server Configuration
PORT=9099
NODE_ENV=production

# Database
DB_FILE=/data/color_management.db

# Timezone
TZ=Asia/Shanghai

# Auth / Access Control (A4)
AUTH_ENFORCE_WRITES=false
READ_ONLY_MODE=false
SESSION_TTL_HOURS=12
# Required when using approval endpoints: /api/auth/admin/*
INTERNAL_ADMIN_KEY=change-this-before-production

# Docker Hub Configuration (for GitHub Actions)
# Add these as GitHub Secrets, not in .env file!
# DOCKER_HUB_USERNAME=your-dockerhub-username
# DOCKER_HUB_TOKEN=your-dockerhub-token

# Synology Deployment
HOST_PORT=9099
DOCKER_IMAGE=yourusername/stereowood-color-system:latest
