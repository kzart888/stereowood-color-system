{
  "name": "stereowood-color-system",
  "version": "0.9.8",
  "description": "STEREOWOOD Color Management System - Simplified for Factory Use (3-5 users)",
  "main": "server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/restore.js",
    "smoke:phase0": "node scripts/phase0-smoke.js",
    "smoke:contract": "node scripts/api-contract-smoke.js",
    "audit:encoding": "node scripts/encoding-audit.js",
    "audit:frontend-contract": "node scripts/frontend-runtime-contract.js",
    "audit:boundaries": "node scripts/check-architecture-boundaries.js",
    "phase0:verify": "npm run audit:encoding && npm run smoke:phase0",
    "phaseA:a0:verify": "npm run phase0:verify && npm run audit:frontend-contract && npm run smoke:contract",
    "phaseA:a1:verify": "npm run phaseA:a0:verify && npm run audit:boundaries",
    "phaseA:a3:db-dryrun": "node scripts/phaseA-a3-db-dryrun.js",
    "phaseA:a3:api-smoke": "node scripts/phaseA-a3-api-smoke.js",
    "phaseA:a3:verify": "npm run phaseA:a3:db-dryrun && npm run phaseA:a3:api-smoke && npm run phase0:verify"
  },
  "keywords": [
    "color-management",
    "stereowood",
    "factory",
    "internal-tool"
  ],
  "author": "STEREOWOOD Team",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.6",
    "sqlite3": "^5.1.7",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
